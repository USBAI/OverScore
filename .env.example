# Copy this file to .env.local and fill in values.
# NEVER commit .env.local — it's in .gitignore.

# OpenRouter (https://openrouter.ai) — required for AI predictions
VITE_OPENROUTER_API_KEY=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

# Optional: override the first two models in the fallback chain.
# If both slots are empty the client walks a built-in list of free models
# (Gemini 2.0 Flash → DeepSeek v3.1 → Llama 3.3 70B → Qwen 2.5 72B → ...).
VITE_OPENROUTER_MODEL=
VITE_OPENROUTER_FALLBACK_MODEL=

# TheSportsDB free key — "3" is the public free key, no signup needed
VITE_SPORTSDB_KEY=3
